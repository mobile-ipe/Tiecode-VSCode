{
  "name": "tiecode-vscode",
  "displayName": "结绳开发工具",
  "description": "为结绳语言提供 VSCode 语言服务、工程模板和构建命令。",
  "version": "0.1.0",
  "publisher": "tiecode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mobile-ipe/Tiecode-VSCode.git"
  },
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:project.json",
    "workspaceContains:tiecode.project.json",
    "workspaceContains:**/project.json",
    "workspaceContains:**/tiecode.project.json",
    "onLanguage:tiecode",
    "onLanguage:tly",
    "onCommand:tiecode.reloadProject",
    "onCommand:tiecode.lintWorkspace",
    "onCommand:tiecode.runProject",
    "onCommand:tiecode.openConfig",
    "onCommand:tiecode.buildAndroid",
    "onCommand:tiecode.buildCxx",
    "onCommand:tiecode.buildHtml",
    "onCommand:tiecode.createAndroidProject",
    "onCommand:tiecode.createCxxProject",
    "onCommand:tiecode.createHtmlProject",
    "onCommand:tiecode.generateEvent",
    "onCommand:tiecode.smartEnter",
    "onCommand:tiecode.scanUiClasses",
    "onCommand:tiecode.showSyncedSource",
    "onCommand:tiecode.exportTlyLayout",
    "onCommand:tiecode.applyTlyLayout",
    "onDebug:tiecode",
    "onView:tiecode.configView"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "languages": [
      {
        "id": "tiecode",
        "aliases": [
          "Tiecode",
          "结绳"
        ],
        "extensions": [
          ".t"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "tly",
        "aliases": [
          "TLY",
          "结绳布局"
        ],
        "extensions": [
          ".tly"
        ],
        "configuration": "./tly-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tiecode",
        "scopeName": "source.tiecode",
        "path": "./syntaxes/tiecode.tmLanguage.json"
      },
      {
        "language": "tly",
        "scopeName": "source.tly",
        "path": "./syntaxes/tly.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tiecode",
        "path": "./snippets/tiecode.json"
      },
      {
        "language": "tly",
        "path": "./snippets/tly.json"
      }
    ],
    "commands": [
      {
        "command": "tiecode.reloadProject",
        "title": "结绳: 重新加载工程"
      },
      {
        "command": "tiecode.lintWorkspace",
        "title": "结绳: 检查整个工程"
      },
      {
        "command": "tiecode.runProject",
        "title": "结绳: 运行工程"
      },
      {
        "command": "tiecode.openConfig",
        "title": "结绳: 打开运行配置"
      },
      {
        "command": "tiecode.buildAndroid",
        "title": "结绳: 构建安卓工程"
      },
      {
        "command": "tiecode.buildCxx",
        "title": "结绳: 构建 CXX 工程"
      },
      {
        "command": "tiecode.buildHtml",
        "title": "结绳: 构建网页工程"
      },
      {
        "command": "tiecode.createAndroidProject",
        "title": "结绳: 创建安卓工程"
      },
      {
        "command": "tiecode.createCxxProject",
        "title": "结绳: 创建 CXX 工程"
      },
      {
        "command": "tiecode.createHtmlProject",
        "title": "结绳: 创建网页工程"
      },
      {
        "command": "tiecode.generateEvent",
        "title": "结绳: 生成事件方法"
      },
      {
        "command": "tiecode.smartEnter",
        "title": "结绳: 智能键入"
      },
      {
        "command": "tiecode.scanUiClasses",
        "title": "结绳: 扫描可视化组件"
      },
      {
        "command": "tiecode.showSyncedSource",
        "title": "结绳: 查看 IDE 同步源码"
      },
      {
        "command": "tiecode.exportTlyLayout",
        "title": "结绳: 导出 TLY 布局"
      },
      {
        "command": "tiecode.applyTlyLayout",
        "title": "结绳: 应用 TLY 布局"
      }
    ],
    "debuggers": [
      {
        "type": "tiecode",
        "label": "结绳",
        "languages": [
          "tiecode"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "tiecode"
                ],
                "default": "tiecode"
              },
              "request": {
                "type": "string",
                "enum": [
                  "launch"
                ],
                "default": "launch"
              },
              "name": {
                "type": "string",
                "default": "运行结绳工程"
              },
              "projectKind": {
                "type": "string",
                "enum": [
                  "auto",
                  "android",
                  "cxx",
                  "html"
                ],
                "default": "auto",
                "description": "运行的结绳工程类型。"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "tiecode",
            "request": "launch",
            "name": "运行结绳工程",
            "projectKind": "auto"
          }
        ],
        "configurationSnippets": [
          {
            "label": "结绳: 运行工程",
            "description": "构建并运行当前结绳工程。",
            "body": {
              "type": "tiecode",
              "request": "launch",
              "name": "运行结绳工程",
              "projectKind": "auto"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tiecode",
          "title": "结绳",
          "icon": "assets/tiecode-view.svg"
        }
      ]
    },
    "views": {
      "tiecode": [
        {
          "id": "tiecode.configView",
          "name": "运行配置",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "tiecode.reloadProject"
        },
        {
          "command": "tiecode.lintWorkspace"
        },
        {
          "command": "tiecode.runProject"
        },
        {
          "command": "tiecode.openConfig"
        },
        {
          "command": "tiecode.buildAndroid"
        },
        {
          "command": "tiecode.buildCxx"
        },
        {
          "command": "tiecode.buildHtml"
        },
        {
          "command": "tiecode.createAndroidProject"
        },
        {
          "command": "tiecode.createCxxProject"
        },
        {
          "command": "tiecode.createHtmlProject"
        },
        {
          "command": "tiecode.generateEvent"
        },
        {
          "command": "tiecode.smartEnter"
        },
        {
          "command": "tiecode.scanUiClasses"
        },
        {
          "command": "tiecode.showSyncedSource"
        },
        {
          "command": "tiecode.exportTlyLayout"
        },
        {
          "command": "tiecode.applyTlyLayout"
        }
      ],
      "editor/context": [
        {
          "command": "tiecode.generateEvent",
          "when": "editorLangId == tiecode",
          "group": "navigation"
        },
        {
          "command": "tiecode.showSyncedSource",
          "when": "editorLangId == tiecode",
          "group": "navigation"
        },
        {
          "command": "tiecode.exportTlyLayout",
          "when": "editorLangId == tiecode",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tiecode.smartEnter",
        "key": "ctrl+alt+enter",
        "mac": "cmd+alt+enter",
        "when": "editorTextFocus && editorLangId == tiecode"
      }
    ],
    "configurationDefaults": {
      "[tiecode]": {
        "editor.semanticHighlighting.enabled": true
      },
      "[tly]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "结绳",
      "properties": {
        "tiecode.compiler.root": {
          "type": "string",
          "default": "D:\\Projects\\CrossPlatform\\Tiecode-Compiler",
          "description": "结绳编译器根目录。"
        },
        "tiecode.compiler.tiecPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "tiec 可执行文件路径。为空时从编译器根目录推断。"
        },
        "tiecode.compiler.stdlibsPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "结绳标准库目录。为空时使用编译器根目录下的 stdlibs。"
        },
        "tiecode.languageService.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用编译器 WASM IDE Service。"
        },
        "tiecode.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用结绳代码诊断。"
        },
        "tiecode.highlight.engine": {
          "type": "string",
          "default": "hybrid",
          "enum": [
            "hybrid",
            "sweetline",
            "compiler",
            "textmate"
          ],
          "enumDescriptions": [
            "优先使用 SweetLine WASM，高亮不可用时回退到编译器语义高亮。",
            "只使用 SweetLine WASM 高亮。",
            "只使用编译器 IDE Service 语义高亮。",
            "关闭语义高亮，仅使用 VS Code TextMate 基础高亮。"
          ],
          "description": "结绳编辑器高亮引擎。"
        },
        "tiecode.sourceVersion": {
          "type": "number",
          "default": 47,
          "enum": [
            40,
            46,
            47
          ],
          "description": "默认结绳源码版本。"
        },
        "tiecode.project.platform": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "android",
            "windows",
            "linux",
            "html"
          ],
          "description": "未声明工程类型时的目标平台。"
        },
        "tiecode.build.outputDirectory": {
          "type": "string",
          "default": "${workspaceFolder}\\build",
          "description": "构建输出目录。"
        },
        "tiecode.build.mode": {
          "type": "string",
          "default": "debug",
          "enum": [
            "debug",
            "release"
          ],
          "description": "默认打包模式。"
        },
        "tiecode.build.defines": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "description": "传给 tiec、IDE Service 和 SweetLine 的默认宏定义。"
        },
        "tiecode.android.gradle": {
          "type": "boolean",
          "default": true,
          "description": "安卓构建是否输出 Gradle 工程结构。"
        },
        "tiecode.cxx.runCmake": {
          "type": "boolean",
          "default": true,
          "description": "CXX 工程执行 tiec 后是否自动运行 CMake 配置和构建。"
        },
        "tiecode.cxx.executableName": {
          "type": "string",
          "default": "main",
          "description": "CXX 工程 F5 运行时优先查找的可执行文件名。"
        },
        "tiecode.cxx.cmakeCommand": {
          "type": "string",
          "default": "cmake",
          "description": "CMake 命令路径或命令名。"
        },
        "tiecode.cxx.cmakeGenerator": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "CMake generator。为空时使用 CMake 默认 generator。"
        },
        "tiecode.cxx.cmakeBuildType": {
          "type": "string",
          "default": "Debug",
          "description": "CXX 工程 CMake 构建类型。"
        },
        "tiecode.cxx.cmakeBuildDirectory": {
          "type": "string",
          "default": "${workspaceFolder}\\build\\cmake",
          "description": "CXX 工程 CMake 构建目录。"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "1.89.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "pinyin-pro": "^3.28.1"
  }
}
