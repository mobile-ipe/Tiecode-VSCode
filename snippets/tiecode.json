{
  "类": {
    "prefix": "class",
    "body": [
      "类 ${1:类名}",
      "    $0",
      "结束 类"
    ],
    "description": "创建结绳类"
  },
  "方法": {
    "prefix": "method",
    "body": [
      "方法 ${1:方法名}(${2})${3}",
      "    $0",
      "结束 方法"
    ],
    "description": "创建方法"
  },
  "事件": {
    "prefix": "event",
    "body": [
      "事件 ${1:对象}:${2:事件名}(${3})",
      "    $0",
      "结束 事件"
    ],
    "description": "创建事件方法"
  },
  "安卓窗口": {
    "prefix": "android-window",
    "body": [
      "类 启动窗口 : 窗口",
      "    @组件配置({宽度=-1, 高度=-1, 纵向布局=真}, 根布局=真)",
      "    变量 根布局 : 线性布局",
      "",
      "    @组件配置({内容=\"你好，结绳\", 宽度=-1, 高度=-2}, 父布局=根布局)",
      "    变量 标题 : 文本框",
      "",
      "    事件 启动窗口:创建完毕()",
      "        $0",
      "    结束 事件",
      "结束 类"
    ],
    "description": "创建安卓启动窗口"
  },
  "网页入口": {
    "prefix": "html-page",
    "body": [
      "类 启动页 : 网页",
      "    @组件配置({宽度=\"100%\", 纵向布局=真}, 根布局=真)",
      "    变量 根布局 : 线性布局",
      "",
      "    @组件配置({内容=\"你好，结绳\", 字体大小=\"20px\"}, 父布局=根布局)",
      "    变量 标题 : 文本框",
      "",
      "    事件 启动页:创建完毕()",
      "        $0",
      "    结束 事件",
      "结束 类"
    ],
    "description": "创建网页启动页"
  },
  "CXX入口": {
    "prefix": "cxx-main",
    "body": [
      "类 启动类",
      "    方法 启动方法()",
      "        $0",
      "    结束 方法",
      "结束 类"
    ],
    "description": "创建 CXX 启动类"
  }
}
